{
  "name": "qasm-language-support",
  "displayName": "OpenQASM 3.0 Interpreter and Language Support",
  "description": "Language support and interpreter for OpenQASM 3.0 with one-click execution",
  "version": "1.2.8",
  "publisher": "quantumvm",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiji1/QuantumVM-VSCode.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:qasm"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "qasm",
        "aliases": [
          "QASM",
          "OpenQASM",
          "qasm"
        ],
        "extensions": [
          ".qasm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "qasm",
        "scopeName": "source.qasm",
        "path": "./syntaxes/qasm.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "qasm.runFile",
        "title": "Run QASM File",
        "category": "QASM",
        "icon": "$(play)"
      },
      {
        "command": "quantumvm.checkForUpdates",
        "title": "Check for Updates",
        "category": "QuantumVM"
      }
    ],
    "keybindings": [
      {
        "command": "qasm.runFile",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus && resourceLangId == qasm"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "qasm.runFile",
          "when": "resourceLangId == qasm",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "qasm.runFile",
          "when": "resourceLangId == qasm",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "QASM Language Server",
      "properties": {
        "qasmLanguageServer.serverPath": {
          "type": "string",
          "default": "qasm-lsp",
          "description": "Path to the QASM language server executable. Leave as 'qasm-lsp' to automatically download the latest version from GitHub releases."
        },
        "qasmLanguageServer.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        },
        "quantumvm.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check for and download binary updates from GitHub releases on extension startup"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node_modules/.bin/tsc -p ./",
    "watch": "node_modules/.bin/tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
